extends ../layout

block sidebar-nav
  a.sidebar-nav-item(href="/student") 
    i.fas.fa-user-graduate
    | My Profile
  a.sidebar-nav-item(href="/student/gpa")
    i.fas.fa-chart-line
    | Academic Trends

block content
  .mb-3
    a.btn.btn-sm.btn-secondary.mb-2(href="/student")
      i.fas.fa-arrow-left
      |  Back to Profile
    h1 Detailed Term Results
    if results && results.length
       p.text-muted
         span.badge.badge-info #{results[0].programme_name}
         |  #{results[0].academic_year} | Semester #{results[0].semester_number}

  if semesterGPA
    .card.mb-3(style="border-left: 4px solid var(--color-primary);")
      .card-body.flex.items-center.justify-between
        div
          h3(style="margin: 0; color: var(--color-text-muted); font-size: 1rem; text-transform: uppercase;") Term GPA
          p(style="margin: 0; font-size: 2rem; font-weight: 700; color: var(--color-primary);") #{semesterGPA.toFixed(2)}
        i.fas.fa-award.fa-3x(style="color: var(--color-primary); opacity: 0.2;")

  .card
    .card-header
      h2 Course Breakdown
      span.text-muted Individual subject performance

    .table-responsive
      table
        thead
          tr
            th Course Code
            th Course Name
            th Credits
            th Marks
            th Max
            th Final Grade
        tbody
          if results && results.length
            each res in results
              tr
                td
                  strong.text-primary #{res.subject_code}
                td #{res.subject_name}
                td #{res.credit_hours}
                td 
                  strong #{res.marks}
                td.text-muted #{res.max_marks}
                td
                  span.badge(class=`badge-${res.grade_letter === 'F' ? 'danger' : 'success'}`) #{res.grade_letter}
          else
             tr
               td(colspan="6").text-center.py-3 No detailed results found.