extends ../layout

block sidebar-nav
  a.sidebar-nav-item.active(href="/student") 
    i.fas.fa-user-graduate
    | My Profile
  a.sidebar-nav-item(href="/student/gpa")
    i.fas.fa-chart-line
    | Academic Trends

block content
  .card.mb-3(style="background: linear-gradient(135deg, var(--color-primary) 0%, #312e81 100%); color: white; border: none;")
    .card-body(style="padding: var(--spacing-xl);")
      .flex.justify-between.items-center(style="flex-wrap: wrap; gap: 1rem;")
        div
          h1(style="color: white; border: none; margin-bottom: 0.5rem; padding: 0;") Welcome back, #{user.username}!
          p(style="color: rgba(255,255,255,0.8); margin: 0; font-size: 1.1rem;") 
            strong ID:
            |  #{student.registration_number}
        div(style="text-align: right;")
          span.badge.badge-success(style="font-size: 0.875rem; padding: 0.5em 1em;") #{student.programme_name}

  .d-flex.justify-between.items-center.mb-2.mt-3
    h2 Recent Academic Results
    .flex.gap-2
      a.btn.btn-sm.btn-secondary(href="/student/gpa")
        i.fas.fa-chart-bar
        |  View Trends
      a.btn.btn-sm.btn-secondary(href="/student/transcript")
        i.fas.fa-download
        |  Download Transcript

  .card
    if results && results.length
      .table-responsive
        table
          thead
            tr
              th Academic Term
              th Course/Subject
              th Marks Obtained
              th Final Grade
              th Grade Point
          tbody
            each res in results
              tr
                td
                  span.badge.badge-info #{student.programme_name}
                  div
                    span.text-muted #{res.academic_year} (S#{res.semester_number})
                td 
                  strong #{res.subject_name}
                td #{res.marks}
                td
                  span.badge(class=`badge-${res.grade_letter === 'F' ? 'danger' : (res.grade_letter.includes('A') ? 'success' : 'info')}`) #{res.grade_letter}
                td
                  strong #{res.grade_point}
    else
      .text-center.py-3
        i.fas.fa-box-open.fa-3x.text-muted.mb-2
        p.text-muted No official results have been published for you yet.
