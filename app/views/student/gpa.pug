extends ../layout

block sidebar-nav
  a.sidebar-nav-item(href="/student") 
    i.fas.fa-user-graduate
    | My Profile
  a.sidebar-nav-item.active(href="/student/gpa")
    i.fas.fa-chart-line
    | Academic Trends

block content
  .mb-3
    a.btn.btn-sm.btn-secondary.mb-2(href="/student")
      i.fas.fa-arrow-left
      |  Back to Profile
    h1 GPA Progression

  .card
    .card-header
      h2 Semester Performance
      span.text-muted Track your academic standing over time
      
    if gpas && gpas.length
      .table-responsive
        table
          thead
            tr
              th Academic Year
              th Semester
              th Grade Point Average (GPA)
              th Status
          tbody
            each gpa in gpas
              tr
                td 
                  strong #{gpa.academic_year}
                td Semester #{gpa.semester_number}
                td
                  - var val = gpa.gpa ? parseFloat(gpa.gpa) : 0;
                  strong(style=`color: ${val >= 3.0 ? 'var(--color-success)' : (val < 2.0 ? 'var(--color-danger)' : 'var(--color-warning)')}; font-size: 1.1rem;`)
                    | #{gpa.gpa ? val.toFixed(2) : 'N/A'}
                td
                  if val >= 3.5
                    span.badge.badge-success Excellent
                  else if val >= 2.5
                    span.badge.badge-info Good
                  else if val >= 2.0
                    span.badge.badge-warning Satisfactory
                  else if val > 0
                    span.badge.badge-danger Needs Improvement
                  else
                    span.badge.badge-secondary N/A
    else
      .text-center.py-3
        i.fas.fa-chart-line.fa-3x.text-muted.mb-2
        p.text-muted No GPA data available yet.