extends ../layout

block sidebar-nav
  a.sidebar-nav-item(href="/faculty") 
    i.fas.fa-chalkboard-teacher
    | Faculty Dashboard

block content
  .mb-3
    a.btn.btn-sm.btn-secondary.mb-2(href="/faculty")
      i.fas.fa-arrow-left
      |  Back to Assignments
    h1 #{allocation.subject_name}
    p.text-muted 
      span.badge.badge-info #{allocation.programme_name}
      |  #{allocation.academic_year} | Semester #{allocation.semester_number} | Max Marks: #{allocation.max_marks}

  .grid-form
    .card
      .card-header
        h3 Import from CSV
        span.text-muted Batch upload marks
      .card-body
        form(method="POST", action=`/faculty/import-csv/${allocation.allocation_id}`, enctype="multipart/form-data")
          .form-group
            label(for="csvFile") Upload File (.csv)
            input(type="file", name="csvFile", id="csvFile", accept=".csv" required style="border: 2px dashed var(--color-border); padding: 1rem; text-align: center; cursor: pointer;")
            p.text-muted.mt-1(style="font-size: 0.75rem;") Format: registration_number, marks
          button.btn.btn-secondary.btn-block(type="submit")
            i.fas.fa-upload
            |  Upload CSV

    .card(style="grid-column: span 2 / span 2;")
      .card-header
        h3 Manual Entry
        span.text-muted Enter marks individually
      .card-body
        form(method="POST", action=`/faculty/result-entry/${allocation.allocation_id}`)
          .table-responsive(style="max-height: 500px; overflow-y: auto;")
            table
              thead(style="position: sticky; top: 0; z-index: 10;")
                tr
                  th Student ID
                  th Full Name
                  th Marks Obtained
                  th Status
              tbody
                each enr in enrollments
                  tr
                    td 
                      strong #{enr.registration_number}
                    td #{enr.username}
                    td
                      input(type="number", name=`mark_${enr.enrollment_id}`, value=enr.marks_obtained || '', min="0", max=allocation.max_marks, step="0.01" required style="max-width: 120px;")
                    td 
                      if enr.entry_status === 'ENTERED'
                         span.badge.badge-success Entered
                      else
                         span.badge.badge-warning Pending
          .flex.justify-end.mt-3
            button.btn.btn-primary(type="submit")
              i.fas.fa-save
              |  Save Submissions