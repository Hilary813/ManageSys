extends ../layout

block sidebar-nav
  a.sidebar-nav-item.active(href="/faculty") 
    i.fas.fa-chalkboard-teacher
    | Faculty Dashboard

block content
  .d-flex.justify-between.items-center.mb-3
    h1 Faculty Portal
    .badge.badge-info
      i.fas.fa-user-circle.mr-2
      |  Logged in as #{user.username}

  .card
    .card-header
      h2 My Teaching Assignments
      span.text-muted Manage academic subjects and enter term results
      
    if subjects && subjects.length
      .table-responsive
        table
          thead
            tr
              th Course Name
              th Academic Term
              th Deadline
              th Progress
              th Actions
          tbody
            each sub in subjects
              tr
                td 
                  strong.text-primary #{sub.subject_name}
                td 
                  span.badge.badge-info #{sub.programme_name}
                  div
                    span.text-muted(style="font-size: 0.8rem;") #{sub.academic_year} (S#{sub.semester_number})
                td #{new Date(sub.end_date).toLocaleDateString()}
                td 
                  - var progressPercent = sub.total_students ? Math.round((sub.entered_marks / sub.total_students) * 100) : 0
                  .flex.items-center
                    .progress-bar-container(style="flex: 1; height: 8px; background: #e2e8f0; border-radius: 4px; margin-right: 8px; overflow: hidden;")
                      .progress-bar-fill(style=`width: ${progressPercent}%; height: 100%; background: ${progressPercent === 100 ? 'var(--color-success)' : 'var(--color-primary)'};`)
                    span.text-muted(style="font-size: 0.75rem; min-width: 40px;") #{sub.entered_marks}/#{sub.total_students}
                td
                  .flex.gap-1
                    a.btn.btn-sm.btn-primary(href=`/faculty/result-entry/${sub.allocation_id}`) 
                      i.fas.fa-edit
                      |  Enter Marks
                    a.btn.btn-sm.btn-secondary(href=`/faculty/performance/${sub.allocation_id}`) 
                      i.fas.fa-chart-line
                      |  Insights
    else
      .text-center.py-3
        i.fas.fa-clipboard-check.fa-3x.text-muted.mb-2
        p.text-muted No subjects are currently assigned to you for this term.
