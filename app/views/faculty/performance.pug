extends ../layout

block sidebar-nav
  a.sidebar-nav-item(href="/faculty") 
    i.fas.fa-chalkboard-teacher
    | Faculty Dashboard

block content
  .mb-3
    a.btn.btn-sm.btn-secondary.mb-2(href="/faculty")
      i.fas.fa-arrow-left
      |  Back to Assignments
    h1 Class Performance Analysis

  .stats-grid
    .stat-card
      .stat-icon.primary
        i.fas.fa-calculator
      .stat-content
        h3 Average Score
        p.stat-value #{stats.average ? Number(stats.average).toFixed(2) : 'N/A'}

    .stat-card
      .stat-icon.info
        i.fas.fa-users
      .stat-content
        h3 Total Students Evaluated
        p.stat-value #{stats.total || 0}

  .card(style="max-width: 800px; margin: 0 auto;")
    .card-header
      h2 Grade Distribution
      span.text-muted A breakdown of student performance by grade tier
    
    .table-responsive
      table
        thead
          tr
            th Grade
            th Score Range
            th Number of Students
            th Percentage
        tbody
          - var total = parseInt(stats.total) || 1; // Prevent div by zero
          
          tr
            td
              span.badge.badge-success A
            td.text-muted 85+
            td 
              strong #{stats.a_count || 0}
            td
               .flex.items-center
                 .progress-bar-container(style="flex: 1; height: 6px; background: #e2e8f0; border-radius: 3px; margin-right: 8px;")
                   .progress-bar-fill(style=`width: ${((stats.a_count || 0) / total) * 100}%; height: 100%; background: var(--color-success); border-radius: 3px;`)
                 span.text-muted(style="font-size: 0.75rem;") #{Math.round(((stats.a_count || 0) / total) * 100)}%
                 
          tr
            td
              span.badge.badge-info B
            td.text-muted 70–84
            td 
              strong #{stats.b_count || 0}
            td
               .flex.items-center
                 .progress-bar-container(style="flex: 1; height: 6px; background: #e2e8f0; border-radius: 3px; margin-right: 8px;")
                   .progress-bar-fill(style=`width: ${((stats.b_count || 0) / total) * 100}%; height: 100%; background: var(--color-secondary); border-radius: 3px;`)
                 span.text-muted(style="font-size: 0.75rem;") #{Math.round(((stats.b_count || 0) / total) * 100)}%
                 
          tr
            td
              span.badge.badge-warning C
            td.text-muted 55–69
            td 
              strong #{stats.c_count || 0}
            td
               .flex.items-center
                 .progress-bar-container(style="flex: 1; height: 6px; background: #e2e8f0; border-radius: 3px; margin-right: 8px;")
                   .progress-bar-fill(style=`width: ${((stats.c_count || 0) / total) * 100}%; height: 100%; background: var(--color-warning); border-radius: 3px;`)
                 span.text-muted(style="font-size: 0.75rem;") #{Math.round(((stats.c_count || 0) / total) * 100)}%
                 
          tr
            td
              span.badge.badge-secondary D
            td.text-muted 40–54
            td 
              strong #{stats.d_count || 0}
            td
               .flex.items-center
                 .progress-bar-container(style="flex: 1; height: 6px; background: #e2e8f0; border-radius: 3px; margin-right: 8px;")
                   .progress-bar-fill(style=`width: ${((stats.d_count || 0) / total) * 100}%; height: 100%; background: var(--color-text-muted); border-radius: 3px;`)
                 span.text-muted(style="font-size: 0.75rem;") #{Math.round(((stats.d_count || 0) / total) * 100)}%

          tr
            td
              span.badge.badge-danger F
            td.text-muted <40 (Fail)
            td 
              strong.text-danger #{stats.f_count || 0}
            td
               .flex.items-center
                 .progress-bar-container(style="flex: 1; height: 6px; background: #e2e8f0; border-radius: 3px; margin-right: 8px;")
                   .progress-bar-fill(style=`width: ${((stats.f_count || 0) / total) * 100}%; height: 100%; background: var(--color-danger); border-radius: 3px;`)
                 span.text-muted(style="font-size: 0.75rem;") #{Math.round(((stats.f_count || 0) / total) * 100)}%