extends layout

//- Override the default wrapper for the guest layout
block wrapper
  .guest-layout
    .login-card
      .login-header
        i.fas.fa-graduation-cap.fa-3x(style="margin-bottom: 10px; color: #a5b4fc;")
        h1 SRMS Gateway
        p Sign in to your account
      
      .login-body
        if error
          .badge.badge-danger(style="display: block; text-align: center; margin-bottom: 1rem; font-size: 0.875rem;") #{error}
          
        form(action="/login", method="POST")
          .form-group
            label(for="email") Email Address
            input#email(type="email", name="username", placeholder="Enter your email", required)
            
          .form-group
            label(for="password") Password
            input#password(type="password", name="password", placeholder="Enter your password", required)
            
          button.btn.btn-primary.btn-block.mt-2(type="submit")
            i.fas.fa-sign-in-alt
            |  Sign In
        
        .text-center.mt-3.text-muted(style="font-size: 0.875rem;")
          p &copy; 2026 Student Result Management System
