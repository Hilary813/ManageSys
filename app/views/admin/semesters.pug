block sidebar-nav
  a.sidebar-nav-item(href="/admin") 
    i.fas.fa-tachometer-alt
    | Dashboard
  a.sidebar-nav-item(href="/admin/programmes") 
    i.fas.fa-graduation-cap
    | Programmes
  a.sidebar-nav-item(href="/admin/students")
    i.fas.fa-user-graduate
    | Students
  a.sidebar-nav-item(href="/admin/subjects")
    i.fas.fa-book
    | Subjects
  a.sidebar-nav-item.active(href="/admin/semesters")
    i.fas.fa-calendar-alt
    | Semesters
  a.sidebar-nav-item(href="/admin/enrollments")
    i.fas.fa-clipboard-list
    | Enrollments
  a.sidebar-nav-item(href="/admin/allocations")
    i.fas.fa-chalkboard-teacher
    | Allocations
  a.sidebar-nav-item(href="/admin/results")
    i.fas.fa-poll
    | Results
  a.sidebar-nav-item(href="/admin/reports")
    i.fas.fa-chart-bar
    | Reports
  a.sidebar-nav-item(href="/admin/users")
    i.fas.fa-users-cog
    | Users

block content
  .d-flex.justify-between.items-center.mb-3
    h1 Academic Terms
    button.btn.btn-primary(onclick="document.getElementById('addModal').classList.add('show')")
      i.fas.fa-plus-circle
      |  New Semester

  .card
    .card-header
      h2 Semester Configuration
      span.text-muted Define academic terms, years, and duration
      
    if semesters && semesters.length
      .table-responsive
        table
          thead
            tr
              th Academic Year
              th Semester
              th Programme
              th Date Range
              th Actions
          tbody
            each sem in semesters
              tr
                td 
                  strong #{sem.academic_year}
                td Sem #{sem.semester_number}
                td 
                  span.badge.badge-info #{sem.programme_name}
                td.text-muted #{new Date(sem.start_date).toLocaleDateString()} - #{new Date(sem.end_date).toLocaleDateString()}
                td
                  .flex.gap-1
                    button.btn.btn-sm.btn-secondary(data-semester-id=sem.semester_id, onclick="editSemester(this)") 
                      i.fas.fa-edit
                    button.btn.btn-sm.btn-danger(data-semester-id=sem.semester_id, onclick="deleteSemester(this)") 
                      i.fas.fa-trash
    else
      p.text-muted.text-center.py-3 No semesters configured.

  // Add Semester Modal
  #addModal.modal
    .modal-content
      .modal-header
        h3 Define New Semester
        span.close(onclick="closeModal('addModal')") &times;
      .modal-body
        form(method="POST", action="/admin/semesters")
          .form-group
            label(for="programme_id") Target Programme
            select(name="programme_id" id="programme_id" required)
              option(value="" disabled selected) Select programme
              each prog in programmes
                option(value=prog.programme_id) #{prog.programme_name}
          .form-row
            .form-group
              label(for="semester_number") Semester Number
              input(type="number", name="semester_number", id="semester_number", placeholder="e.g. 1" required min="1" max="10")
            .form-group
              label(for="academic_year") Academic Year
              input(type="text", name="academic_year", id="academic_year", placeholder="e.g. 2025-2026" required)
          .form-row
            .form-group
              label(for="start_date") Start Date
              input(type="date", name="start_date", id="start_date" required)
            .form-group
              label(for="end_date") End Date
              input(type="date", name="end_date", id="end_date" required)
          
          .flex.justify-end.mt-3.gap-2
            button.btn.btn-secondary(type="button", onclick="closeModal('addModal')") Cancel
            button.btn.btn-primary(type="submit") Create

  // Edit Semester Modal
  #editModal.modal
    .modal-content
      .modal-header
        h3 Update Semester Properties
        span.close(onclick="closeModal('editModal')") &times;
      .modal-body
        form#editForm(method="POST")
          input(type="hidden", name="_method", value="PUT")
          .form-group
            label(for="edit_programme_id") Target Programme
            select(name="programme_id" id="edit_programme_id" required)
              each prog in programmes
                option(value=prog.programme_id) #{prog.programme_name}
          .form-row
            .form-group
              label(for="edit_semester_number") Semester Number
              input(type="number", name="semester_number", id="edit_semester_number" required)
            .form-group
              label(for="edit_academic_year") Academic Year
              input(type="text", name="academic_year", id="edit_academic_year" required)
          .form-row
            .form-group
              label(for="edit_start_date") Start Date
              input(type="date", name="start_date", id="edit_start_date" required)
            .form-group
              label(for="edit_end_date") End Date
              input(type="date", name="end_date", id="edit_end_date" required)
          
          .flex.justify-end.mt-3.gap-2
            button.btn.btn-secondary(type="button", onclick="closeModal('editModal')") Cancel
            button.btn.btn-primary(type="submit") Save Changes

  script.
    // Helper function to format date string from rendered text back to YYYY-MM-DD input format might be tricky depending on locale, 
    // it's better to render data attributes with raw values for edit forms in a robust app.
    // Given the constraints we'll rely on the server handling or prompt user to re-select dates. Let's try basic extraction.
    function editSemester(button) {
      const semesterId = button.getAttribute('data-semester-id');
      const row = button.closest('tr');
      const cells = row.querySelectorAll('td');
      
      document.getElementById('edit_academic_year').value = cells[0].textContent.trim();
      document.getElementById('edit_semester_number').value = cells[1].textContent.trim().replace('Sem ', '');
      
      const progText = cells[2].textContent.trim();
      const select = document.getElementById('edit_programme_id');
      for (let i = 0; i < select.options.length; i++) {
          if (select.options[i].text === progText) {
              select.selectedIndex = i;
              break;
          }
      }
      
      // We will skip dates to avoid locale parsing issues without a library, forcing user to input valid dates when editing.
      
      document.getElementById('editForm').action = `/admin/semesters/${semesterId}`;
      document.getElementById('editModal').classList.add('show');
    }

    function deleteSemester(button) {
      if (confirm('Are you definitely sure? Deleting a semester cascades and removes enrollments and results.')) {
        const semesterId = button.getAttribute('data-semester-id');
        const form = document.createElement('form');
        form.method = 'POST';
        form.action = `/admin/semesters/${semesterId}`;
        
        const methodInput = document.createElement('input');
        methodInput.type = 'hidden';
        methodInput.name = '_method';
        methodInput.value = 'DELETE';
        form.appendChild(methodInput);
        
        document.body.appendChild(form);
        form.submit();
      }
    }