extends ../layout

block sidebar-nav
  a.sidebar-nav-item(href="/admin") 
    i.fas.fa-tachometer-alt
    | Dashboard
  a.sidebar-nav-item(href="/admin/programmes") 
    i.fas.fa-graduation-cap
    | Programmes
  a.sidebar-nav-item.active(href="/admin/students")
    i.fas.fa-user-graduate
    | Students
  a.sidebar-nav-item(href="/admin/subjects")
    i.fas.fa-book
    | Subjects
  a.sidebar-nav-item(href="/admin/semesters")
    i.fas.fa-calendar-alt
    | Semesters
  a.sidebar-nav-item(href="/admin/enrollments")
    i.fas.fa-clipboard-list
    | Enrollments
  a.sidebar-nav-item(href="/admin/allocations")
    i.fas.fa-chalkboard-teacher
    | Allocations
  a.sidebar-nav-item(href="/admin/results")
    i.fas.fa-poll
    | Results
  a.sidebar-nav-item(href="/admin/reports")
    i.fas.fa-chart-bar
    | Reports
  a.sidebar-nav-item(href="/admin/users")
    i.fas.fa-users-cog
    | Users

block content
  .d-flex.justify-between.items-center.mb-3
    h1 Student Directory
    button.btn.btn-primary(onclick="document.getElementById('addModal').classList.add('show')")
      i.fas.fa-user-plus
      |  Register Student

  .card
    .card-header
      h2 Enrolled Students
      span.text-muted Manage student records and programme assignments
      
    if students && students.length
      .table-responsive
        table
          thead
            tr
              th Registration No.
              th Name (Username)
              th Email
              th Programme
              th Enrollment Year
              th Actions
          tbody
            each student in students
              tr
                td 
                  strong.text-primary #{student.registration_number}
                td #{student.username}
                td #{student.email}
                td 
                  span.badge.badge-info #{student.programme_name}
                td #{student.enrollment_year}
                td
                  .flex.gap-1
                    button.btn.btn-sm.btn-secondary(data-student-id=student.student_id, onclick="editStudent(this)") 
                      i.fas.fa-edit
                    button.btn.btn-sm.btn-danger(data-student-id=student.student_id, onclick="deleteStudent(this)") 
                      i.fas.fa-trash
    else
      p.text-muted.text-center.py-3 No students found in the system.

  // Register Student Modal
  #addModal.modal
    .modal-content
      .modal-header
        h3 Register New Student
        span.close(onclick="closeModal('addModal')") &times;
      .modal-body
        form(method="POST", action="/admin/students")
          .form-row
            .form-group
              label(for="username") Full Name / Username
              input(type="text", name="username", id="username", placeholder="Enter full name" required)
            .form-group
              label(for="email") Email Address
              input(type="email", name="email", id="email", placeholder="student@example.com" required)
          .form-row
            .form-group
              label(for="password") Initial Password
              input(type="password", name="password", id="password", placeholder="Set password" required)
            .form-group
              label(for="registration_number") Registration Number (ID)
              input(type="text", name="registration_number", id="registration_number", placeholder="e.g. STU2026XX" required)
          .form-row
            .form-group
              label(for="programme_id") Programme / Course
              select(name="programme_id" id="programme_id" required)
                option(value="" disabled selected) Select a programme
                each prog in programmes
                  option(value=prog.programme_id) #{prog.programme_name}
            .form-group
              label(for="enrollment_year") Enrollment Year
              input(type="number", name="enrollment_year", id="enrollment_year", placeholder="e.g. 2026" required min="2000" max="2100")
          
          .flex.justify-end.mt-3.gap-2
            button.btn.btn-secondary(type="button", onclick="closeModal('addModal')") Cancel
            button.btn.btn-primary(type="submit") Complete Registration

  // Edit Student Modal
  #editModal.modal
    .modal-content
      .modal-header
        h3 Edit Student Profile
        span.close(onclick="closeModal('editModal')") &times;
      .modal-body
        form#editForm(method="POST")
          input(type="hidden", name="_method", value="PUT")
          .form-row
            .form-group
              label(for="edit_username") Name / Username
              input(type="text", name="username", id="edit_username" required)
            .form-group
              label(for="edit_email") Email
              input(type="email", name="email", id="edit_email" required)
          .form-row
            .form-group
              label(for="edit_registration_number") Registration Number
              input(type="text", name="registration_number", id="edit_registration_number" required)
            .form-group
              label(for="edit_enrollment_year") Enrollment Year
              input(type="number", name="enrollment_year", id="edit_enrollment_year" required)
          .form-group
            label(for="edit_programme_id") Programme
            select(name="programme_id" id="edit_programme_id" required)
              each prog in programmes
                option(value=prog.programme_id) #{prog.programme_name}
          
          .flex.justify-end.mt-3.gap-2
            button.btn.btn-secondary(type="button", onclick="closeModal('editModal')") Cancel
            button.btn.btn-primary(type="submit") Save Changes

  script.
    function editStudent(button) {
      const studentId = button.getAttribute('data-student-id');
      const row = button.closest('tr');
      const cells = row.querySelectorAll('td');
      
      document.getElementById('edit_registration_number').value = cells[0].textContent.trim();
      document.getElementById('edit_username').value = cells[1].textContent.trim();
      document.getElementById('edit_email').value = cells[2].textContent.trim();
      // Programme handle relies on text match or storing data attribute, for simplicity we trust the server handles it if untouched or requires manual reselection if text doesn't match perfectly. 
      // Ideally we'd set the value directly based on an ID attribute.
      document.getElementById('edit_enrollment_year').value = cells[4].textContent.trim();
      
      // Let's try to match the select option by text
      const programmeText = cells[3].textContent.trim();
      const select = document.getElementById('edit_programme_id');
      for (let i = 0; i < select.options.length; i++) {
          if (select.options[i].text === programmeText) {
              select.selectedIndex = i;
              break;
          }
      }

      document.getElementById('editForm').action = `/admin/students/${studentId}`;
      document.getElementById('editModal').classList.add('show');
    }

    function deleteStudent(button) {
      if (confirm('Are you certain you want to remove this student? This action cannot be undone and will affect associated records.')) {
        const studentId = button.getAttribute('data-student-id');
        const form = document.createElement('form');
        form.method = 'POST';
        form.action = `/admin/students/${studentId}`;
        
        const methodInput = document.createElement('input');
        methodInput.type = 'hidden';
        methodInput.name = '_method';
        methodInput.value = 'DELETE';
        form.appendChild(methodInput);
        
        document.body.appendChild(form);
        form.submit();
      }
    }