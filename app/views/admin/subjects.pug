extends ../layout

block sidebar-nav
  a.sidebar-nav-item(href="/admin") 
    i.fas.fa-tachometer-alt
    | Dashboard
  a.sidebar-nav-item(href="/admin/programmes") 
    i.fas.fa-graduation-cap
    | Programmes
  a.sidebar-nav-item(href="/admin/students")
    i.fas.fa-user-graduate
    | Students
  a.sidebar-nav-item.active(href="/admin/subjects")
    i.fas.fa-book
    | Subjects
  a.sidebar-nav-item(href="/admin/semesters")
    i.fas.fa-calendar-alt
    | Semesters
  a.sidebar-nav-item(href="/admin/enrollments")
    i.fas.fa-clipboard-list
    | Enrollments
  a.sidebar-nav-item(href="/admin/allocations")
    i.fas.fa-chalkboard-teacher
    | Allocations
  a.sidebar-nav-item(href="/admin/results")
    i.fas.fa-poll
    | Results
  a.sidebar-nav-item(href="/admin/reports")
    i.fas.fa-chart-bar
    | Reports
  a.sidebar-nav-item(href="/admin/users")
    i.fas.fa-users-cog
    | Users

block content
  .d-flex.justify-between.items-center.mb-3
    h1 Subject Catalog
    button.btn.btn-primary(onclick="document.getElementById('addModal').classList.add('show')")
      i.fas.fa-plus-circle
      |  Add Subject

  .card
    .card-header
      h2 Course Directory
      span.text-muted Manage academic subjects and credit hours
      
    if subjects && subjects.length
      .table-responsive
        table
          thead
            tr
              th Subject Code
              th Subject Name
              th Credit Hours
              th Max Marks
              th Actions
          tbody
            each sub in subjects
              tr
                td
                  strong.text-primary #{sub.subject_code}
                td #{sub.subject_name}
                td 
                  span.badge.badge-info #{sub.credit_hours} Credits
                td #{sub.max_marks}
                td
                  .flex.gap-1
                    button.btn.btn-sm.btn-secondary(data-subject-id=sub.subject_id, onclick="editSubject(this)") 
                      i.fas.fa-edit
                    button.btn.btn-sm.btn-danger(data-subject-id=sub.subject_id, onclick="deleteSubject(this)") 
                      i.fas.fa-trash
    else
      p.text-muted.text-center.py-3 No subjects configured yet.

  // Add Subject Modal
  #addModal.modal
    .modal-content
      .modal-header
        h3 Add New Subject
        span.close(onclick="closeModal('addModal')") &times;
      .modal-body
        form(method="POST", action="/admin/subjects")
          .form-row
            .form-group
              label(for="subject_code") Subject Code
              input(type="text", name="subject_code", id="subject_code", placeholder="e.g. CS101" required)
            .form-group
              label(for="subject_name") Subject Name
              input(type="text", name="subject_name", id="subject_name", placeholder="e.g. Introduction to Programming" required)
          .form-row
            .form-group
              label(for="credit_hours") Credit Hours
              input(type="number", name="credit_hours", id="credit_hours", placeholder="e.g. 3" required min="1" max="10")
            .form-group
              label(for="max_marks") Max Marks
              input(type="number", name="max_marks", id="max_marks", placeholder="e.g. 100" required min="1")
          
          .flex.justify-end.mt-3.gap-2
            button.btn.btn-secondary(type="button", onclick="closeModal('addModal')") Cancel
            button.btn.btn-primary(type="submit") Create Subject

  // Edit Subject Modal
  #editModal.modal
    .modal-content
      .modal-header
        h3 Edit Subject
        span.close(onclick="closeModal('editModal')") &times;
      .modal-body
        form#editForm(method="POST")
          input(type="hidden", name="_method", value="PUT")
          .form-row
            .form-group
              label(for="edit_subject_code") Subject Code
              input(type="text", name="subject_code", id="edit_subject_code" required)
            .form-group
              label(for="edit_subject_name") Subject Name
              input(type="text", name="subject_name", id="edit_subject_name" required)
          .form-row
            .form-group
              label(for="edit_credit_hours") Credit Hours
              input(type="number", name="credit_hours", id="edit_credit_hours" required min="1" max="10")
            .form-group
              label(for="edit_max_marks") Max Marks
              input(type="number", name="max_marks", id="edit_max_marks" required min="1")
          
          .flex.justify-end.mt-3.gap-2
            button.btn.btn-secondary(type="button", onclick="closeModal('editModal')") Cancel
            button.btn.btn-primary(type="submit") Save Changes

  script.
    function editSubject(button) {
      const subjectId = button.getAttribute('data-subject-id');
      const row = button.closest('tr');
      const cells = row.querySelectorAll('td');
      
      document.getElementById('edit_subject_code').value = cells[0].textContent.trim();
      document.getElementById('edit_subject_name').value = cells[1].textContent.trim();
      document.getElementById('edit_credit_hours').value = cells[2].textContent.trim().split(' ')[0]; // Extract number from "X Credits"
      document.getElementById('edit_max_marks').value = cells[3].textContent.trim();
      
      document.getElementById('editForm').action = `/admin/subjects/${subjectId}`;
      document.getElementById('editModal').classList.add('show');
    }

    function deleteSubject(button) {
      if (confirm('Are you sure you want to delete this subject? This affects existing enrollments and results.')) {
        const subjectId = button.getAttribute('data-subject-id');
        const form = document.createElement('form');
        form.method = 'POST';
        form.action = `/admin/subjects/${subjectId}`;
        
        const methodInput = document.createElement('input');
        methodInput.type = 'hidden';
        methodInput.name = '_method';
        methodInput.value = 'DELETE';
        form.appendChild(methodInput);
        
        document.body.appendChild(form);
        form.submit();
      }
    }