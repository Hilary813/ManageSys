extends ../layout

block sidebar-nav
  a.sidebar-nav-item.active(href="/admin") 
    i.fas.fa-tachometer-alt
    | Dashboard
  a.sidebar-nav-item(href="/admin/programmes") 
    i.fas.fa-graduation-cap
    | Programmes
  a.sidebar-nav-item(href="/admin/students")
    i.fas.fa-user-graduate
    | Students
  a.sidebar-nav-item(href="/admin/subjects")
    i.fas.fa-book
    | Subjects
  a.sidebar-nav-item(href="/admin/semesters")
    i.fas.fa-calendar-alt
    | Semesters
  a.sidebar-nav-item(href="/admin/enrollments")
    i.fas.fa-clipboard-list
    | Enrollments
  a.sidebar-nav-item(href="/admin/allocations")
    i.fas.fa-chalkboard-teacher
    | Allocations
  a.sidebar-nav-item(href="/admin/results")
    i.fas.fa-poll
    | Results
  a.sidebar-nav-item(href="/admin/reports")
    i.fas.fa-chart-bar
    | Reports
  a.sidebar-nav-item(href="/admin/users")
    i.fas.fa-users-cog
    | Users

block content
  .d-flex.justify-between.items-center.mb-3
    h1 Dashboard Overview
    .badge.badge-info
      i.fas.fa-user-circle.mr-2
      |  Logged in as #{user.username} (Admin)

  .stats-grid
    .stat-card
      .stat-icon.primary
        i.fas.fa-user-graduate
      .stat-content
        h3 Total Students
        p.stat-value #{stats.totalStudents}

    .stat-card
      .stat-icon.success
        i.fas.fa-book
      .stat-content
        h3 Total Subjects
        p.stat-value #{stats.totalSubjects}

    .stat-card
      .stat-icon.warning
        i.fas.fa-calendar-alt
      .stat-content
        h3 Active Semesters
        p.stat-value #{stats.activeSemesters}

    .stat-card
      .stat-icon.danger
        i.fas.fa-tasks
      .stat-content
        h3 Pending Submissions
        p.stat-value #{stats.pendingSubmissions}

  .card
    .card-header
      h2 Current Examination Sessions
      a.btn.btn-sm.btn-secondary(href="/admin/results") View All Results
    
    if sessions && sessions.length
      .table-responsive
        table
          thead
            tr
              th Semester Target
              th Programme
              th Subjects
              th Submitted
              th Status
          tbody
            each session in sessions
              tr
                td
                  strong #{session.academic_year}
                  span.text-muted  - Sem #{session.semester_number}
                td #{session.programme_name}
                td #{session.subjects}
                td #{session.submitted}
                td 
                  if session.submitted === session.subjects
                    span.badge.badge-success Complete
                  else
                    span.badge.badge-warning Pending
    else
      p.text-muted.text-center.py-3 No examination sessions found.
