extends ../layout

block sidebar-nav
  a.sidebar-nav-item(href="/admin") 
    i.fas.fa-tachometer-alt
    | Dashboard
  a.sidebar-nav-item(href="/admin/programmes") 
    i.fas.fa-graduation-cap
    | Programmes
  a.sidebar-nav-item(href="/admin/students")
    i.fas.fa-user-graduate
    | Students
  a.sidebar-nav-item(href="/admin/subjects")
    i.fas.fa-book
    | Subjects
  a.sidebar-nav-item(href="/admin/semesters")
    i.fas.fa-calendar-alt
    | Semesters
  a.sidebar-nav-item(href="/admin/enrollments")
    i.fas.fa-clipboard-list
    | Enrollments
  a.sidebar-nav-item(href="/admin/allocations")
    i.fas.fa-chalkboard-teacher
    | Allocations
  a.sidebar-nav-item(href="/admin/results")
    i.fas.fa-poll
    | Results
  a.sidebar-nav-item(href="/admin/reports")
    i.fas.fa-chart-bar
    | Reports
  a.sidebar-nav-item.active(href="/admin/users")
    i.fas.fa-users-cog
    | Users

block content
  .d-flex.justify-between.items-center.mb-3
    h1 User Management
    button.btn.btn-primary(onclick="document.getElementById('addModal').classList.add('show')")
      i.fas.fa-plus
      |  New User

  .card
    .card-header
      h2 System Users
      span.text-muted Manage admins, faculty, and students
      
    if users && users.length
      .table-responsive
        table
          thead
            tr
              th Username
              th Email
              th Role
              th Status
              th Actions
          tbody
            each usr in users
              tr
                td
                  .flex.items-center
                    i.fas.fa-user.text-muted(style="margin-right: 8px;")
                    strong #{usr.username}
                td #{usr.email}
                td 
                  if usr.role === 'ADMIN'
                    span.badge.badge-danger Admin
                  else if usr.role === 'FACULTY'
                    span.badge.badge-info Faculty
                  else
                    span.badge.badge-success Student
                td 
                  if usr.is_active
                    span.badge.badge-success Active
                  else
                    span.badge.badge-warning Inactive
                td
                  .flex.gap-1
                    button.btn.btn-sm.btn-secondary(data-user-id=usr.user_id, data-username=usr.username, data-email=usr.email, data-role=usr.role, data-active=usr.is_active, onclick="editUser(this)") 
                      i.fas.fa-edit
                    button.btn.btn-sm.btn-danger(data-user-id=usr.user_id, onclick="deleteUser(this)") 
                      i.fas.fa-trash
    else
      p.text-muted.text-center.py-3 No users found.

  // Add User Modal
  #addModal.modal
    .modal-content
      .modal-header
        h3 Create New User
        span.close(onclick="closeModal('addModal')") &times;
      .modal-body
        form(method="POST", action="/admin/users")
          .form-group
            label(for="username") Username
            input(type="text", name="username", id="username", placeholder="Enter username" required)
          .form-group
            label(for="email") Email Address
            input(type="email", name="email", id="email", placeholder="Enter email" required)
          .form-group
            label(for="password") Password
            input(type="password", name="password", id="password", placeholder="Enter password" required)
          .form-group
            label(for="role") System Role
            select(name="role" id="role" required)
              option(value="ADMIN") Administrator
              option(value="FACULTY") Faculty
              option(value="STUDENT") Student
          .flex.justify-end.mt-3.gap-2
            button.btn.btn-secondary(type="button", onclick="closeModal('addModal')") Cancel
            button.btn.btn-primary(type="submit") Create

  // Edit User Modal
  #editModal.modal
    .modal-content
      .modal-header
        h3 Edit User
        span.close(onclick="closeModal('editModal')") &times;
      .modal-body
        form#editForm(method="POST")
          input(type="hidden", name="_method", value="PUT")
          .form-group
            label(for="edit_username") Username
            input(type="text", name="username", id="edit_username" required)
          .form-group
            label(for="edit_email") Email
            input(type="email", name="email", id="edit_email" required)
          .form-group
            label(for="edit_password") Password (leave blank to keep current)
            input(type="password", name="password", id="edit_password")
          .form-group
            label(for="edit_role") System Role
            select(name="role", id="edit_role" required)
              option(value="ADMIN") Administrator
              option(value="FACULTY") Faculty
              option(value="STUDENT") Student
          .form-group
            label(for="edit_is_active") Account Status
            select(name="is_active", id="edit_is_active" required)
              option(value="1") Active
              option(value="0") Inactive
          .flex.justify-end.mt-3.gap-2
            button.btn.btn-secondary(type="button", onclick="closeModal('editModal')") Cancel
            button.btn.btn-primary(type="submit") Save Changes

  script.
    function editUser(button) {
      const userId = button.getAttribute('data-user-id');
      document.getElementById('edit_username').value = button.getAttribute('data-username');
      document.getElementById('edit_email').value = button.getAttribute('data-email');
      document.getElementById('edit_role').value = button.getAttribute('data-role');
      document.getElementById('edit_is_active').value = button.getAttribute('data-active') === "true" || button.getAttribute('data-active') == 1 ? "1" : "0";
      
      document.getElementById('editForm').action = `/admin/users/${userId}`;
      document.getElementById('editModal').classList.add('show');
    }

    function deleteUser(button) {
      if (confirm('Are you sure you want to delete this user? This action cannot be undone.')) {
        const userId = button.getAttribute('data-user-id');
        const form = document.createElement('form');
        form.method = 'POST';
        form.action = `/admin/users/${userId}`;
        
        const methodInput = document.createElement('input');
        methodInput.type = 'hidden';
        methodInput.name = '_method';
        methodInput.value = 'DELETE';
        form.appendChild(methodInput);
        
        document.body.appendChild(form);
        form.submit();
      }
    }