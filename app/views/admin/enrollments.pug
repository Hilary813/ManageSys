extends ../layout

block sidebar-nav
  a.sidebar-nav-item(href="/admin") 
    i.fas.fa-tachometer-alt
    | Dashboard
  a.sidebar-nav-item(href="/admin/programmes") 
    i.fas.fa-graduation-cap
    | Programmes
  a.sidebar-nav-item(href="/admin/students")
    i.fas.fa-user-graduate
    | Students
  a.sidebar-nav-item(href="/admin/subjects")
    i.fas.fa-book
    | Subjects
  a.sidebar-nav-item(href="/admin/semesters")
    i.fas.fa-calendar-alt
    | Semesters
  a.sidebar-nav-item.active(href="/admin/enrollments")
    i.fas.fa-clipboard-list
    | Enrollments
  a.sidebar-nav-item(href="/admin/allocations")
    i.fas.fa-chalkboard-teacher
    | Allocations
  a.sidebar-nav-item(href="/admin/results")
    i.fas.fa-poll
    | Results
  a.sidebar-nav-item(href="/admin/reports")
    i.fas.fa-chart-bar
    | Reports
  a.sidebar-nav-item(href="/admin/users")
    i.fas.fa-users-cog
    | Users

block content
  .d-flex.justify-between.items-center.mb-3
    h1 Enrollments
    .d-flex.gap-2
      button.btn.btn-secondary(onclick="document.getElementById('bulkEnrollModal').classList.add('show')")
        i.fas.fa-users
        |  Bulk Enroll
      button.btn.btn-primary(onclick="document.getElementById('addModal').classList.add('show')")
        i.fas.fa-user-plus
        |  Enroll Student

  .card
    .card-header
      h2 Course Enrollments
      span.text-muted Manage student enrollment in specific subjects and terms
      
    if enrollments && enrollments.length
      .table-responsive
        table
          thead
            tr
              th RollNo
              th Name
              th Subject
              th Semester
              th Actions
          tbody
            each enr in enrollments
              tr
                td 
                  strong #{enr.registration_number}
                td #{enr.username}
                td #{enr.subject_name}
                td 
                  span.badge.badge-info Sem #{enr.semester_number}
                  span.text-muted  (#{enr.academic_year})
                td
                  .flex.gap-1
                    button.btn.btn-sm.btn-secondary(data-enrollment-id=enr.enrollment_id, data-student-id=enr.student_id, data-subject-id=enr.subject_id, data-semester-id=enr.semester_id, onclick="editEnrollment(this)") 
                      i.fas.fa-edit
                    button.btn.btn-sm.btn-danger(data-enrollment-id=enr.enrollment_id, onclick="deleteEnrollment(this)") 
                      i.fas.fa-trash
    else
      p.text-muted.text-center.py-3 No current enrollments.

  // Bulk Enroll Modal
  #bulkEnrollModal.modal
    .modal-content
      .modal-header
        h3 Bulk Enroll by Programme
        span.close(onclick="closeModal('bulkEnrollModal')") &times;
      .modal-body
        form(method="POST", action="/admin/enrollments/bulk")
          .form-group
            label(for="bulk_programme_id") Target Programme
            select(name="programme_id" id="bulk_programme_id" required)
              option(value="" disabled selected) Select programme
              if programmes
                each prog in programmes
                  option(value=prog.programme_id) #{prog.programme_name}
          .form-group
            label(for="bulk_semester_id") Target Semester
            select(name="semester_id" id="bulk_semester_id" required)
              option(value="" disabled selected) Select academic term
              each sem in semesters
                option(value=sem.semester_id) #{sem.academic_year} - Sem #{sem.semester_number}
          .form-group
            label(for="bulk_subject_id") Assign Subject
            select(name="subject_id" id="bulk_subject_id" required)
              option(value="" disabled selected) Select subject to enroll in
              each sub in subjects
                option(value=sub.subject_id) #{sub.subject_name}
          .flex.justify-end.mt-3.gap-2
            button.btn.btn-secondary(type="button", onclick="closeModal('bulkEnrollModal')") Cancel
            button.btn.btn-primary(type="submit") Process Bulk Enrollment

  // Add Enrollment Modal
  #addModal.modal
    .modal-content
      .modal-header
        h3 New Enrollment
        span.close(onclick="closeModal('addModal')") &times;
      .modal-body
        form(method="POST", action="/admin/enrollments")
          .form-group
            label(for="student_id") Student
            select(name="student_id" id="student_id" required)
              option(value="" disabled selected) Select student
              each stud in students
                option(value=stud.student_id) #{stud.registration_number} - #{stud.username}
          .form-group
            label(for="subject_id") Subject
            select(name="subject_id" id="subject_id" required)
              option(value="" disabled selected) Select subject
              each sub in subjects
                option(value=sub.subject_id) #{sub.subject_name}
          .form-group
            label(for="semester_id") Academic Term
            select(name="semester_id" id="semester_id" required)
              option(value="" disabled selected) Select semester
              each sem in semesters
                option(value=sem.semester_id) #{sem.academic_year} - Sem #{sem.semester_number}
          .flex.justify-end.mt-3.gap-2
            button.btn.btn-secondary(type="button", onclick="closeModal('addModal')") Cancel
            button.btn.btn-primary(type="submit") Create

  // Edit Enrollment Modal
  #editModal.modal
    .modal-content
      .modal-header
        h3 Edit Enrollment
        span.close(onclick="closeModal('editModal')") &times;
      .modal-body
        form#editForm(method="POST")
          input(type="hidden", name="_method", value="PUT")
          .form-group
            label(for="edit_student_id") Student
            select(name="student_id", id="edit_student_id" required)
              each stud in students
                option(value=stud.student_id) #{stud.registration_number} - #{stud.username}
          .form-group
            label(for="edit_subject_id") Subject
            select(name="subject_id", id="edit_subject_id" required)
              each sub in subjects
                option(value=sub.subject_id) #{sub.subject_name}
          .form-group
            label(for="edit_semester_id") Academic Term
            select(name="semester_id", id="edit_semester_id" required)
              each sem in semesters
                option(value=sem.semester_id) #{sem.academic_year} - Sem #{sem.semester_number}
          .flex.justify-end.mt-3.gap-2
            button.btn.btn-secondary(type="button", onclick="closeModal('editModal')") Cancel
            button.btn.btn-primary(type="submit") Save Changes

  script.
    function editEnrollment(button) {
      document.getElementById('edit_student_id').value = button.getAttribute('data-student-id');
      document.getElementById('edit_subject_id').value = button.getAttribute('data-subject-id');
      document.getElementById('edit_semester_id').value = button.getAttribute('data-semester-id');
      
      document.getElementById('editForm').action = `/admin/enrollments/${button.getAttribute('data-enrollment-id')}`;
      document.getElementById('editModal').classList.add('show');
    }

    function deleteEnrollment(button) {
      if (confirm('Delete this enrollment? This removes associated marks and results.')) {
        const form = document.createElement('form');
        form.method = 'POST';
        form.action = `/admin/enrollments/${button.getAttribute('data-enrollment-id')}`;
        
        const methodInput = document.createElement('input');
        methodInput.type = 'hidden';
        methodInput.name = '_method';
        methodInput.value = 'DELETE';
        form.appendChild(methodInput);
        
        document.body.appendChild(form);
        form.submit();
      }
    }