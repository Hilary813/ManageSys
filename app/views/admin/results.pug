extends ../layout

block sidebar-nav
  a.sidebar-nav-item(href="/admin") 
    i.fas.fa-tachometer-alt
    | Dashboard
  a.sidebar-nav-item(href="/admin/programmes") 
    i.fas.fa-graduation-cap
    | Programmes
  a.sidebar-nav-item(href="/admin/students")
    i.fas.fa-user-graduate
    | Students
  a.sidebar-nav-item(href="/admin/subjects")
    i.fas.fa-book
    | Subjects
  a.sidebar-nav-item(href="/admin/semesters")
    i.fas.fa-calendar-alt
    | Semesters
  a.sidebar-nav-item(href="/admin/enrollments")
    i.fas.fa-clipboard-list
    | Enrollments
  a.sidebar-nav-item(href="/admin/allocations")
    i.fas.fa-chalkboard-teacher
    | Allocations
  a.sidebar-nav-item.active(href="/admin/results")
    i.fas.fa-poll
    | Results
  a.sidebar-nav-item(href="/admin/reports")
    i.fas.fa-chart-bar
    | Reports
  a.sidebar-nav-item(href="/admin/users")
    i.fas.fa-users-cog
    | Users

block content
  .d-flex.justify-between.items-center.mb-3
    h1 Results Administration
    button.btn.btn-primary(onclick="document.getElementById('publishModal').classList.add('show')")
      i.fas.fa-broadcast-tower
      |  Publish Results

  .card
    .card-header
      h2 Academic Results
      span.text-muted View and manage student grades
      
    if results && results.length
      .table-responsive
        table
          thead
            tr
              th Student
              th Subject
              th Semester
              th Marks
              th Grade
              th Status
              th Action
          tbody
            each res in results
              - var displayMarks = (res.marks != null) ? res.marks : res.marks_obtained
              tr
                td
                  strong #{res.registration_number}
                  div.text-muted(style="font-size:0.8rem") #{res.username}
                td #{res.subject_name}
                td 
                  span.text-muted #{res.academic_year} (S#{res.semester_number})
                td 
                  if displayMarks != null
                    strong #{displayMarks}
                  else
                    span.text-muted —
                td
                  if res.grade_letter
                    span.badge(class=`badge-${res.grade_letter === 'F' ? 'danger' : 'success'}`) #{res.grade_letter}
                  else
                    span.badge.badge-secondary —
                td
                  if res.result_status === 'PUBLISHED'
                    span.badge.badge-success Published
                  else if res.result_status === 'PENDING'
                    span.badge.badge-warning Pending
                  else if res.marks_status === 'SUBMITTED'
                    span.badge.badge-info Submitted
                  else
                    span.badge.badge-secondary Not Entered
                td
                  if res.result_status === 'PUBLISHED'
                    form(method="POST", action="/admin/results/withhold" style="display:inline")
                      input(type="hidden", name="result_id", value=res.result_id)
                      button.btn.btn-sm.btn-danger(type="submit")
                        i.fas.fa-ban
                        |  Withhold
    else
      p.text-muted.text-center.py-3 No enrollments found. Enroll students first.

  // Publish Results Modal
  #publishModal.modal
    .modal-content
      .modal-header
        h3 Publish Term Results
        span.close(onclick="closeModal('publishModal')") &times;
      .modal-body
        form(method="POST", action="/admin/results/publish")
          .form-group
            label(for="semester_id") Target Semester
            select(name="semester_id" id="semester_id" required)
              option(value="" disabled selected) Select semester to publish
              each sem in semesters
                option(value=sem.semester_id) #{sem.academic_year} - Sem #{sem.semester_number}
          
          .flex.justify-end.mt-3.gap-2
            button.btn.btn-secondary(type="button", onclick="closeModal('publishModal')") Cancel
            button.btn.btn-primary(type="submit") Publish Now